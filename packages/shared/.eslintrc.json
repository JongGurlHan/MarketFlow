{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "env": {
    "node": true,
    "jest": true,
    "es2021": true
  },
  "extends": ["eslint:recommended"],
  "rules": {
    "no-unused-vars": "off",
    "no-undef": "off",
    "no-empty": "off"
  },
  "ignorePatterns": ["dist", "node_modules", "coverage", "*.config.js"]
}
